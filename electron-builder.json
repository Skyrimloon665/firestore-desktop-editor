{
  "appId": "com.firestore.desktop.editor",
  "productName": "Firestore Desktop Editor",
  "directories": {
    "output": "dist-packaged"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "win": {
    "target": "portable",
    "icon": "assets/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "category": "public.app-category.developer-tools",
    "icon": "assets/icon.icns"
  }
}
