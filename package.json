{
  "name": "firestore-desktop-editor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron server.js server.cjs dist-packaged",
    "lint": "tsc --noEmit",
    "electron:dev": "npm run build && tsc -p tsconfig.electron.json && electron dist-electron/main.js",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder --win --mac",
    "dist:win": "vite build && tsc -p tsconfig.electron.json && electron-builder --win",
    "dist:mac": "vite build && tsc -p tsconfig.electron.json && electron-builder --mac"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "firebase-admin": "^13.0.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@types/express": "^4.17.21",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.firestore.desktop.editor",
    "productName": "Firestore Desktop Editor",
    "directories": {
      "output": "dist-packaged"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
